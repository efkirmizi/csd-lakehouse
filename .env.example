COMPOSE_PROJECT_NAME=csd-lakehouse

# =============================================================================
#  Bu dosya SABLONDUR. Kullanmak icin kopyalayin:
#      Copy-Item .env.example .env
#  ve asagidaki PAROLALARI degistirin.
#
#  '.env' dosyasi .gitignore'dadir ve COMMIT EDILMEZ -- kimlik bilgisi
#  icerir. Repoda paylasilan surum bu dosyadir.
#  (docs/01-mimari.md bolum 8: uretimde bunlar Vault / K8s Secrets'a tasinir.)
# =============================================================================

# ---------------- Surum matrisi (tek yerden yonetilir) ----------------
# Bu dortlu birbirine bagimlidir. Degistirmeden once docs/01-mimari.md
# icindeki "Surum Uyumlulugu" bolumunu okuyun.
SPARK_VERSION=3.5.3
ICEBERG_VERSION=1.9.1
NESSIE_VERSION=0.104.1
PG_JDBC_VERSION=42.7.4

# ---------------- MinIO (Object Storage / S3 API) ----------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=DEGISTIRIN_minio_parolasi
LAKEHOUSE_BUCKET=lakehouse
AWS_REGION=us-east-1

# ---------------- PostgreSQL (OLTP kaynak sistem simulasyonu) ----------------
PG_USER=csd
PG_PASSWORD=DEGISTIRIN_pg_parolasi
PG_DB=csd_oltp

# OLTP seed hacmi. Bu deger seed suresini ve tum performans rakamlarini
# dogrudan belirler:
#     2.000.000  -> seed ~1-2 dk   (hizli demo / gelistirme)
#    20.000.000  -> seed ~10-15 dk (olcek testi -- README'deki rakamlar bundan)
#
# Degistirdikten sonra veriyi bastan uretmek gerekir:
#     docker compose down -v; docker compose up -d
#
# DIKKAT: Buyuk degerlerde seed uzun surer ve yarida kesilirse Postgres
# init'i BIR DAHA CALISTIRMAZ (yarim sema kalir). Kontrol: .\run.ps1 status
# Onarim: .\run.ps1 repair-oltp
OLTP_ISLEM_ROWS=2000000

# ---------------- Nessie ----------------
# Spark bu uctan konusur (Nessie native API)
NESSIE_URI=http://nessie:19120/api/v2
# ClickHouse'un konusacagi Iceberg REST Catalog cephesi.
# NOT: Bu surum ciftinde (ClickHouse 25.6 + Nessie 0.104.1) DataLakeCatalog
# veri okuyamiyor; fiilen icebergS3() kullaniliyor.
# Ayrinti: sql/clickhouse/01_catalog.sql
NESSIE_ICEBERG_REST=http://nessie:19120/iceberg/main

# ---------------- ClickHouse ----------------
CH_USER=analytics
CH_PASSWORD=DEGISTIRIN_ch_parolasi
CH_DB=csd

# ---------------- Airflow (opsiyonel: --profile orchestration) ----------------
# Varsayilan 'docker compose up' Airflow'u BASLATMAZ.
#   docker compose --profile orchestration up -d --build
#   -> http://localhost:8090
AIRFLOW_VERSION=2.10.5
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=DEGISTIRIN_airflow_parolasi
